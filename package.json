{
  "name": "machine-live-dashboard",
  "version": "1.0.0",
  "description": "Factory floor machine live dashboard — SAP batch jobs and status",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f dashboard"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mysql2": "^3.14.3"
  },
  "keywords": ["dashboard", "sap", "production"],
  "license": "ISC"
}
